---
import Base from '../layouts/Base.astro';
import config from '../config';

const base = import.meta.env.BASE_URL;

const categories = [
  {
    title: 'Fromages à la coupe',
    description: 'Gruyère AOP, tommes vaudoises, raclette — on coupe à la demande, on conseille selon le plat ou la saison.',
  },
  {
    title: 'Produits laitiers',
    description: 'Lait frais, yogourts, beurre et crème. Livrés par nos producteurs de la région, renouvelés chaque jour.',
  },
  {
    title: 'Fruits & légumes',
    description: 'Ce qui pousse autour de nous, quand ça pousse. Récoltes de maraîchers proches, au fil des semaines.',
  },
  {
    title: 'Épicerie & terroir',
    description: 'Confitures, miel, pâtes, huiles, vins vaudois — des produits choisis chez des artisans qu\'on connaît.',
  },
];
---

<Base
  title={`${config.siteName} — ${config.tagline}`}
  description={config.description}
  headerVariant="transparent"
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: config.siteName,
      url: config.siteUrl,
      publisher: {
        '@type': 'Organization',
        name: config.siteName,
      },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: config.legal.companyName,
      url: config.siteUrl,
      email: config.legal.email,
      description: config.description,
      address: {
        '@type': 'PostalAddress',
        streetAddress: config.legal.address,
        addressLocality: config.legal.locality,
        postalCode: config.legal.postalCode,
        addressCountry: 'CH',
      },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: config.siteName,
      description: config.description,
      url: config.siteUrl,
      telephone: config.legal.phone,
      email: config.legal.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: config.legal.address,
        addressLocality: config.legal.locality,
        postalCode: config.legal.postalCode,
        addressCountry: 'CH',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 46.538,
        longitude: 6.687,
      },
      image: `${config.siteUrl}/images/storefront.jpg`,
      priceRange: '$$',
    },
  ]}
>
  <!-- ═══════ HERO ═══════ -->
  <section class="hero" id="accueil">
    <div class="container hero-layout">
      <div class="hero-text">
        <p class="hero-eyebrow">Savigny, Vaud</p>
        <h1>
          La laiterie<br />
          du village
        </h1>
        <p>
          Fromages à la coupe, produits laitiers, fruits et légumes de saison, épicerie locale. Ce qu'il faut, d'où il faut, tous les jours.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Passer nous voir</a>
          <a href="#produits" class="btn btn-secondary">Nos produits</a>
        </div>
      </div>
      <div class="hero-image fade-in">
        <img
          src={`${base}/images/storefront.jpg`}
          alt="Devanture de la Laiterie de Savigny"
          loading="eager"
          width="560"
          height="400"
        />
      </div>
    </div>
  </section>

  <!-- ═══════ PHOTOS ═══════ -->
  <section class="photos-strip" aria-label="Photos du magasin">
    <div class="photos-grid">
      <div class="photo-item fade-in">
        <img
          src={`${base}/images/cheese-counter.jpg`}
          alt="Comptoir fromages — Laiterie de Savigny"
          loading="lazy"
          width="640"
          height="480"
        />
      </div>
      <div class="photo-item fade-in">
        <img
          src={`${base}/images/produce-display.jpg`}
          alt="Fruits et légumes de saison"
          loading="lazy"
          width="640"
          height="480"
        />
      </div>
      <div class="photo-item fade-in">
        <img
          src={`${base}/images/epicerie-shelf.jpg`}
          alt="Rayon épicerie et produits du terroir"
          loading="lazy"
          width="640"
          height="480"
        />
      </div>
    </div>
  </section>

  <!-- ═══════ PRODUITS ═══════ -->
  <section class="products-section" id="produits">
    <div class="container">
      <p class="section-label fade-in">Ce qu'on propose</p>
      <h2 class="section-title fade-in">Des produits, pas des promesses</h2>
      <p class="section-subtitle fade-in">
        On travaille avec des producteurs de la région. On connaît les gens, on connaît les produits. C'est aussi simple que ça.
      </p>
      <div class="card-grid">
        {categories.map((cat) => (
          <div class="card fade-in">
            <h3>{cat.title}</h3>
            <p>{cat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ HISTOIRE ═══════ -->
  <section class="story-section" id="histoire">
    <div class="container">
      <div class="story-layout">
        <div class="story-content">
          <p class="section-label fade-in">Le lieu</p>
          <h2 class="section-title fade-in">Une laiterie de village, tout simplement</h2>
          <p class="fade-in">
            La Laiterie de Savigny, c'est un commerce de proximité. Pas un concept, pas une enseigne — un magasin où l'on vient faire ses courses depuis longtemps.
          </p>
          <p class="fade-in">
            On y trouve des fromages coupés à la demande, du lait et des yogourts frais, des fruits et légumes de saison, et une épicerie de produits locaux. Ce qui arrive le matin se retrouve en rayon le jour même.
          </p>
          <p class="fade-in">
            Ici, les gens se connaissent. On prend le temps. On conseille un fromage pour la fondue, on met de côté une tomme pour un habitué. C'est un rythme de village, et c'est ce qu'on aime.
          </p>
        </div>
        <div class="story-image fade-in">
          <img
            src={`${base}/images/storefront.jpg`}
            alt="Laiterie de Savigny — vue extérieure"
            loading="lazy"
            width="480"
            height="600"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CONTACT ═══════ -->
  <section class="contact-section" id="contact">
    <div class="container">
      <p class="section-label fade-in">Pratique</p>
      <h2 class="section-title fade-in">Où nous trouver</h2>
      <div class="contact-grid">
        <div class="contact-card fade-in">
          <h3>Adresse</h3>
          <p>
            Rte des Miguettes 1<br />
            1073 Savigny<br />
            Suisse
          </p>
        </div>
        <div class="contact-card fade-in">
          <h3>Téléphone</h3>
          <p>
            <a href="tel:+41217812056">021 781 20 56</a>
          </p>
          <h3>Email</h3>
          <p>
            <a href="mailto:alaiterie@epicerieslocales.ch">alaiterie@epicerieslocales.ch</a>
          </p>
        </div>
        <div class="contact-card fade-in">
          <h3>Instagram</h3>
          <p>
            Arrivages, nouveautés, vie du magasin.
          </p>
          <a href="https://www.instagram.com/laiterie_savigny" target="_blank" rel="noopener noreferrer" class="contact-link">
            @laiterie_savigny →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CTA FINAL ═══════ -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-banner fade-in">
        <p class="cta-text">Ouvert du lundi au samedi. Passez quand vous voulez.</p>
        <a href="tel:+41217812056" class="btn btn-primary">
          021 781 20 56
        </a>
      </div>
    </div>
  </section>
</Base>

<Fragment slot="scripts">
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
</Fragment>

<style>
  /* ── Hero ── */
  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: 20px;
    opacity: 0;
    animation: fade-up 0.7s var(--ease-out) 0.2s forwards;
  }

  .hero h1 {
    opacity: 0;
    animation: fade-up 0.7s var(--ease-out) 0.3s forwards;
  }

  .hero-text > p {
    opacity: 0;
    animation: fade-up 0.7s var(--ease-out) 0.4s forwards;
  }

  .hero-actions {
    opacity: 0;
    animation: fade-up 0.7s var(--ease-out) 0.5s forwards;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-image {
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: grayscale(30%) contrast(1.05);
    transition: filter 0.5s var(--ease-out);
  }

  .hero-image:hover img {
    filter: grayscale(0%) contrast(1);
  }

  @media (max-width: 900px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-image {
      max-width: 100%;
      order: -1;
    }
  }

  /* ── Photo strip ── */
  .photos-strip {
    padding: 0;
    background: var(--bg);
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .photo-item {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(25%) contrast(1.04);
    transition: filter 0.6s var(--ease-out), transform 0.6s var(--ease-out);
  }

  .photo-item:hover img {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.02);
  }

  @media (max-width: 640px) {
    .photos-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Products section ── */
  .products-section {
    background: var(--bg);
  }

  /* ── Story section ── */
  .story-section {
    background: var(--bg-warm);
  }

  .story-layout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .story-image {
    overflow: hidden;
  }

  .story-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: grayscale(40%) contrast(1.05);
  }

  .story-content .section-label {
    margin-bottom: 10px;
  }

  .story-content .section-title {
    margin-bottom: 24px;
  }

  .story-content p {
    color: var(--text-muted);
    font-size: 0.96rem;
    line-height: 1.85;
    margin-bottom: 16px;
  }

  @media (max-width: 900px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .story-image {
      order: -1;
      max-width: 100%;
    }
  }

  /* ── Contact section ── */
  .contact-section {
    background: var(--bg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .contact-card {
    background: var(--bg-card);
    padding: 32px 28px;
  }

  .contact-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  .contact-card h3:not(:first-child) {
    margin-top: 20px;
  }

  .contact-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .contact-card a {
    color: var(--text);
  }

  .contact-card a:hover {
    color: var(--text-muted);
  }

  .contact-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    transition: opacity 0.25s;
  }

  .contact-link:hover {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Final CTA ── */
  .final-cta {
    padding: 0 0 var(--space-4xl);
  }

  .cta-banner {
    border-top: 1px solid var(--border);
    padding: 48px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cta-text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  @media (max-width: 768px) {
    .cta-banner {
      flex-direction: column;
      align-items: flex-start;
      padding: 36px 0;
      gap: 20px;
    }
  }
</style>

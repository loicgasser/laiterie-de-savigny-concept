---
import config from '../config';

const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang={config.language}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex" />
<title>Page introuvable — {config.siteName}</title>
<style>
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/laiterie-de-savigny-concept/fonts/inter-latin.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: url('/laiterie-de-savigny-concept/fonts/inter-latin.woff2') format('woff2');
  }
  :root {
    --bg: #F7F3EC;
    --text: #2C1810;
    --text-muted: #6B5B4E;
    --accent: #3D6B35;
    --cta: #C45B28;
    --cta-hover: #D4692F;
    --font-body: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-display: Georgia, "Times New Roman", serif;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }
  .container { max-width: 480px; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 5rem);
    color: var(--cta);
    margin-bottom: 1rem;
  }
  p { color: var(--text-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem; }
  a {
    display: inline-block;
    padding: 12px 32px;
    background: var(--cta);
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    transition: background 0.2s;
  }
  a:hover { background: var(--cta-hover); }
  a:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
</style>
</head>
<body>
  <main class="container">
    <h1>404</h1>
    <p>Cette page n'existe pas. Elle a peut-être été déplacée ou vous avez suivi un lien cassé.</p>
    <a href={base}>Retour à l'accueil</a>
  </main>
</body>
</html>

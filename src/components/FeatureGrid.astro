---
export interface FeatureItem {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  tag?: string;
}

interface Props {
  items: FeatureItem[];
  columns?: 2 | 3 | 4;
  variant?: 'card' | 'minimal';
}

const { items, columns = 3, variant = 'card' } = Astro.props;
---

<div class={`feature-grid feature-grid--${variant} feature-grid--cols-${columns}`}>
  {items.map((item) => {
    const Tag = item.href ? 'a' : 'div';
    return (
      <Tag
        class={`feature-item feature-item--${variant}`}
        {...(item.href ? { href: item.href } : {})}
      >
        {item.tag && <span class="feature-tag">{item.tag}</span>}
        {item.icon && <span class="feature-icon">{item.icon}</span>}
        <h3 class="feature-title">{item.title}</h3>
        <p class="feature-desc">{item.description}</p>
      </Tag>
    );
  })}
</div>

<style>
  /* ── Grid layout ── */
  .feature-grid {
    display: grid;
    gap: 20px;
  }

  .feature-grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .feature-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .feature-grid--cols-4 { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 900px) {
    .feature-grid--cols-3,
    .feature-grid--cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .feature-grid {
      grid-template-columns: 1fr !important;
    }
  }

  /* ── Card variant ── */
  .feature-item--card {
    position: relative;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.35s var(--ease-out),
      transform 0.35s var(--ease-out),
      box-shadow 0.35s var(--ease-out),
      background-color 0.35s var(--ease-out);
    overflow: hidden;
  }

  .feature-item--card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), rgba(0, 212, 255, 0.3));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .feature-item--card:hover {
    border-color: rgba(0, 212, 255, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 20px rgba(0, 212, 255, 0.04);
    background-color: rgba(22, 22, 31, 0.9);
  }

  .feature-item--card:hover::before {
    transform: scaleX(1);
  }

  /* ── Minimal variant ── */
  .feature-item--minimal {
    text-decoration: none;
    color: inherit;
    padding: 12px 0;
  }

  /* ── Tag badge ── */
  .feature-tag {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--accent-glow-strong);
    color: var(--accent);
    padding: 3px 10px;
    border-radius: 20px;
  }

  .feature-item--minimal .feature-tag {
    position: static;
    display: inline-block;
    margin-bottom: 8px;
  }

  /* ── Icon ── */
  .feature-icon {
    display: block;
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 16px;
  }

  /* ── Title ── */
  .feature-title {
    font-family: var(--font-mono);
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
    color: var(--text);
  }

  /* ── Description ── */
  .feature-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0;
  }
</style>

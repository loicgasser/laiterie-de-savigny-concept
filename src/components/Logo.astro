---
/**
 * Laiterie de Savigny Logo
 * Monochrome SVG badge reconstructed from storefront signage.
 * Round mark with line-art cheese, milk can, and apples.
 */

interface Props {
  size?: 'small' | 'medium';
  showText?: boolean;
}

const { size = 'medium', showText = true } = Astro.props;
---

<svg
  class={`logo logo-${size}${showText ? '' : ' logo-icon-only'}`}
  viewBox="0 0 240 240"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Laiterie de Savigny"
>
  <!-- Outer circle -->
  <circle cx="120" cy="120" r="114" fill="none" stroke="currentColor" stroke-width="1.8" />

  <!-- Cheese wedge (left) -->
  <g transform="translate(52, 68)">
    <!-- Wedge body — triangular profile with rounded front face -->
    <path
      d="M 0 42 L 30 0 L 52 0 L 52 42 Z"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"
    />
    <!-- Top rind edge -->
    <line x1="30" y1="0" x2="52" y2="0" stroke="currentColor" stroke-width="1.6" />
    <!-- Holes -->
    <circle cx="20" cy="24" r="4.5" fill="none" stroke="currentColor" stroke-width="1.2" />
    <circle cx="36" cy="14" r="3.5" fill="none" stroke="currentColor" stroke-width="1.2" />
    <circle cx="38" cy="30" r="5" fill="none" stroke="currentColor" stroke-width="1.2" />
    <circle cx="14" cy="12" r="2.5" fill="none" stroke="currentColor" stroke-width="1.2" />
  </g>

  <!-- Milk can (center) -->
  <g transform="translate(108, 48)">
    <!-- Can body -->
    <path
      d="M 4 28 C 4 24 0 22 0 18 L 0 62 C 0 66 4 68 10 68 L 18 68 C 24 68 28 66 28 62 L 28 18 C 28 22 24 24 24 28"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"
    />
    <!-- Can shoulder / neck -->
    <path
      d="M 4 28 L 4 22 C 4 18 8 16 10 16 L 18 16 C 20 16 24 18 24 22 L 24 28"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"
    />
    <!-- Lid -->
    <path
      d="M 8 16 L 8 12 C 8 10 10 8 14 8 C 18 8 20 10 20 12 L 20 16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"
    />
    <!-- Lid knob -->
    <circle cx="14" cy="5" r="3" fill="none" stroke="currentColor" stroke-width="1.6" />
    <!-- Handle -->
    <path
      d="M 0 32 C -6 32 -6 50 0 50"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
    />
    <!-- Belt / band -->
    <line x1="0" y1="44" x2="28" y2="44" stroke="currentColor" stroke-width="1.2" />
  </g>

  <!-- Apples (right) -->
  <!-- Larger apple -->
  <g transform="translate(152, 82)">
    <ellipse cx="12" cy="14" rx="12" ry="13" fill="none" stroke="currentColor" stroke-width="1.6" />
    <!-- Stem -->
    <path d="M 12 1 C 12 -2 14 -4 16 -5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
    <!-- Leaf -->
    <path d="M 14 -2 C 18 -4 20 -2 18 0" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
  </g>
  <!-- Smaller apple -->
  <g transform="translate(170, 98)">
    <ellipse cx="8" cy="10" rx="8.5" ry="9" fill="none" stroke="currentColor" stroke-width="1.4" />
    <!-- Stem -->
    <path d="M 8 1 C 8 -1 9 -2 10 -3" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
  </g>

  <!-- Script text "La Laiterie" -->
  {showText ? (
    <>
      <text
        x="120"
        y="158"
        font-size="30"
        font-weight="400"
        font-style="italic"
        text-anchor="middle"
        fill="currentColor"
        font-family="Georgia, 'Times New Roman', serif"
        letter-spacing="-0.5"
      >
        La Laiterie
      </text>
      <text
        x="120"
        y="182"
        font-size="16"
        font-weight="300"
        text-anchor="middle"
        fill="currentColor"
        font-family="'Inter', -apple-system, sans-serif"
        letter-spacing="1.5"
      >
        de Savigny
      </text>
    </>
  ) : (
    <>
      <text
        x="120"
        y="158"
        font-size="30"
        font-weight="400"
        font-style="italic"
        text-anchor="middle"
        fill="currentColor"
        font-family="Georgia, 'Times New Roman', serif"
        letter-spacing="-0.5"
      >
        La Laiterie
      </text>
      <text
        x="120"
        y="182"
        font-size="16"
        font-weight="300"
        text-anchor="middle"
        fill="currentColor"
        font-family="'Inter', -apple-system, sans-serif"
        letter-spacing="1.5"
      >
        de Savigny
      </text>
    </>
  )}
</svg>

<style>
  .logo {
    color: var(--text, #1A1A1A);
    display: inline-block;
    vertical-align: middle;
  }

  .logo-small {
    width: 40px;
    height: 40px;
  }

  .logo-medium {
    width: 52px;
    height: 52px;
  }

  .logo-icon-only {
    width: 48px;
    height: 48px;
  }

  @media (min-width: 769px) {
    .logo-medium {
      width: 56px;
      height: 56px;
    }
  }

  @media (max-width: 640px) {
    .logo-medium {
      width: 44px;
      height: 44px;
    }

    .logo-icon-only {
      width: 40px;
      height: 40px;
    }
  }
</style>

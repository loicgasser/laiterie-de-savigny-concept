---
interface Props {
  username: string;
  label?: string;
  color?: string;
}

const { username, label = 'Support me', color = '#FF5E5B' } = Astro.props;
---

<a
  href={`https://ko-fi.com/${username}`}
  target="_blank"
  rel="noopener noreferrer"
  class="kofi-button"
  style={`background-color: ${color};`}
  aria-label={`Support on Ko-fi: ${label}`}
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.64-4.011 3.64s-.084.042-.17.042a.332.332 0 01-.212-.085 2.3 2.3 0 01-.233-.259c-.259-.348-.36-.753-.36-.753s1.48-1.326 2.147-2.309c.376-.554.502-1.042.502-1.042s.217-.478.217-1.151c0-.674-.37-1.137-.37-1.137s-.232-.327-.792-.327c-.56 0-1.04.476-1.04.476s-.544.476-.544 1.372c0 .897.37 1.487.37 1.487s-.881 1.384-2.07 2.756c-.483.56-.845.776-.845.776s-.398-.343-.668-.95c-.388-.875-.413-2.126-.413-2.126s.019-3.24.019-3.24S6.413 5.88 10.321 5.88c2.573 0 3.72 1.573 3.72 3.36 0 1.787-1.222 3.22-1.222 3.22z" fill="currentColor"/>
  </svg>
  {label}
